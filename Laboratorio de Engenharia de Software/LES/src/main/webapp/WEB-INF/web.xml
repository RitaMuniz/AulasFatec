<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>SistemaLivraria</display-name>

    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>ClienteController</servlet-name>
        <servlet-class>projetoLivraria.controller.ClienteController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ClienteController</servlet-name>
        <url-pattern>/cliente</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>EnderecoController</servlet-name>
        <servlet-class>projetoLivraria.controller.EnderecoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EnderecoController</servlet-name>
        <url-pattern>/endereco</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>projetoLivraria.controller.LoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>projetoLivraria.controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CartaoController</servlet-name>
        <servlet-class>projetoLivraria.controller.CartaoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartaoController</servlet-name>
        <url-pattern>/cartao</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PedidoController</servlet-name>
        <servlet-class>projetoLivraria.controller.PedidoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PedidoController</servlet-name>
        <url-pattern>/pedido</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LivroController</servlet-name>
        <servlet-class>projetoLivraria.controller.LivroController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LivroController</servlet-name>
        <url-pattern>/livros</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>LivroController</servlet-name>
        <url-pattern>/livro</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CarrinhoController</servlet-name>
        <servlet-class>projetoLivraria.controller.CarrinhoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CarrinhoController</servlet-name>
        <url-pattern>/carrinho</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PedidosController</servlet-name>
        <servlet-class>projetoLivraria.controller.PedidosController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PedidosController</servlet-name>
        <url-pattern>/pedidos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminPedidoController</servlet-name>
        <servlet-class>projetoLivraria.controller.AdminPedidoController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminPedidoController</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminPedidoController</servlet-name>
        <url-pattern>/admin/pedidos</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>TrocaController</servlet-name>
        <servlet-class>projetoLivraria.controller.TrocaController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TrocaController</servlet-name>
        <url-pattern>/troca</url-pattern>
    </servlet-mapping>


    <welcome-file-list>
        <welcome-file>/view/index.jsp</welcome-file>
    </welcome-file-list>

</web-app>